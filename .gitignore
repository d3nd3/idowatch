# Root .gitignore: mirrors and scopes rules from sub-repos (angelfit, gadgetbridge)
# so the same files are ignored when those directories are part of this tree.

# ---- angelfit (no .gitignore in sub-repo; common Xcode/macOS ignores) ----
angelfit/.DS_Store
angelfit/**/.DS_Store
angelfit/DerivedData/
angelfit/**/DerivedData/
angelfit/**/xcuserdata/
angelfit/*.xcworkspace/xcuserdata/
angelfit/*.xcodeproj/xcuserdata/
angelfit/*.xcodeproj/project.xcworkspace/xcuserdata/
angelfit/**/*.pbxuser
angelfit/**/*.mode1v3
angelfit/**/*.mode2v3
angelfit/**/*.perspectivev3
angelfit/**/*.moved-aside
angelfit/**/xcshareddata/IDEWorkspaceChecks.plist

# ---- gadgetbridge (from gadgetbridge/.gitignore, scoped under gadgetbridge/) ----
# Built application files
gadgetbridge/*.apk
gadgetbridge/*.ap_
gadgetbridge/**/*.apk
gadgetbridge/**/*.ap_

# Files for the Dalvik VM
gadgetbridge/**/*.dex

# Java class files
gadgetbridge/**/*.class

# Kotlin build files
gadgetbridge/.kotlin

# Generated files
gadgetbridge/bin/
gadgetbridge/gen/
gadgetbridge/**/bin/
gadgetbridge/**/gen/

# Gradle files
gadgetbridge/.gradle/
gadgetbridge/build/
gadgetbridge/**/.gradle/
gadgetbridge/**/build/

# Local configuration file (sdk path, etc)
gadgetbridge/local.properties

# Proguard folder generated by Eclipse
gadgetbridge/proguard/
gadgetbridge/**/proguard/

# Log Files
gadgetbridge/**/*.log

# IDE
gadgetbridge/.idea/*
!gadgetbridge/.idea/icon.svg
!gadgetbridge/.idea/dictionaries
gadgetbridge/.idea/dictionaries/*
!gadgetbridge/.idea/dictionaries/t.xml
gadgetbridge/**/*.iml

# Gadgetbridge-specific
gadgetbridge/MPChartLib
gadgetbridge/fw.dirs
gadgetbridge/**/.project
gadgetbridge/**/.settings
gadgetbridge/**/.classpath
gadgetbridge/app/release/output-metadata.json
gadgetbridge/app/.cxx/
gadgetbridge/.attach_pid*

# Nested .gitignore content (GBDaoGenerator, entities, util, res)
gadgetbridge/GBDaoGenerator/bin
gadgetbridge/GBDaoGenerator/build
gadgetbridge/app/src/main/java/nodomain/freeyourgadget/gadgetbridge/util/small/
gadgetbridge/app/src/main/java/nodomain/freeyourgadget/gadgetbridge/util/SmallHelper.java
gadgetbridge/app/src/main/res/values-en

# ---- IDOBlueProtocol (https://github.com/idoosmart/IDOBlueProtocol; no .gitignore upstream) ----
# Swift Package Manager / Xcode
IDOBlueProtocol/.swiftpm/xcode/xcuserdata/
IDOBlueProtocol/.swiftpm/xcode/package.xcworkspace/xcuserdata/
IDOBlueProtocol/.swiftpm/.build/
IDOBlueProtocol/.build/
IDOBlueProtocol/**/.build/
IDOBlueProtocol/DerivedData/
IDOBlueProtocol/**/DerivedData/
IDOBlueProtocol/**/xcuserdata/
IDOBlueProtocol/*.xcworkspace/xcuserdata/
IDOBlueProtocol/*.xcodeproj/xcuserdata/
IDOBlueProtocol/*.xcodeproj/project.xcworkspace/xcuserdata/
# macOS
IDOBlueProtocol/.DS_Store
IDOBlueProtocol/**/.DS_Store
# Xcode user state
IDOBlueProtocol/**/*.xcuserstate
IDOBlueProtocol/**/xcschememanagement.plist

# ---- IDOGitBook (https://github.com/idoosmart/IDOGitBook; no .gitignore upstream) ----
# Mirror style: scoped under IDOGitBook/; typical GitBook / static site ignores
IDOGitBook/.DS_Store
IDOGitBook/**/.DS_Store
IDOGitBook/node_modules/
IDOGitBook/**/node_modules/
IDOGitBook/_book/
IDOGitBook/**/_book/
IDOGitBook/.gitbook/
IDOGitBook/**/.gitbook/
IDOGitBook/*.log
IDOGitBook/**/*.log
IDOGitBook/.cache/
IDOGitBook/**/.cache/
IDOGitBook/book/
IDOGitBook/**/book/

# ---- Flutter / Dart (for Flutter_GitBook and future Flutter tooling) ----
# Build outputs
**/build/
**/.dart_tool/
.dart_tool/

# Flutter/Dart package dependencies (may be regenerated)
.packages
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# IDE / tooling
.idea/
.vscode/
*.iml

# Generated by Flutter/Dart tools
pubspec.lock
analysis_options.yaml

# ---- IDOAndroidBleSDK-_UPDATE (Android Gradle/IDE ignores) ----
IDOAndroidBleSDK-_UPDATE/*.iml
IDOAndroidBleSDK-_UPDATE/.gradle
IDOAndroidBleSDK-_UPDATE/local.properties
IDOAndroidBleSDK-_UPDATE/.idea/
IDOAndroidBleSDK-_UPDATE/build
