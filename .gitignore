# Root .gitignore: mirrors and scopes rules from sub-repos (angelfit, gadgetbridge)
# so the same files are ignored when those directories are part of this tree.

# ---- research/repositories/angelfit (no .gitignore in sub-repo; common Xcode/macOS ignores) ----
research/repositories/angelfit/.DS_Store
research/repositories/angelfit/**/.DS_Store
research/repositories/angelfit/DerivedData/
research/repositories/angelfit/**/DerivedData/
research/repositories/angelfit/**/xcuserdata/
research/repositories/angelfit/*.xcworkspace/xcuserdata/
research/repositories/angelfit/*.xcodeproj/xcuserdata/
research/repositories/angelfit/*.xcodeproj/project.xcworkspace/xcuserdata/
research/repositories/angelfit/**/*.pbxuser
research/repositories/angelfit/**/*.mode1v3
research/repositories/angelfit/**/*.mode2v3
research/repositories/angelfit/**/*.perspectivev3
research/repositories/angelfit/**/*.moved-aside
research/repositories/angelfit/**/xcshareddata/IDEWorkspaceChecks.plist

# ---- gadgetbridge (from gadgetbridge/.gitignore, scoped under gadgetbridge/) ----
# Built application files
gadgetbridge/*.apk
gadgetbridge/*.ap_
gadgetbridge/**/*.apk
gadgetbridge/**/*.ap_

# Files for the Dalvik VM
gadgetbridge/**/*.dex

# Java class files
gadgetbridge/**/*.class

# Kotlin build files
gadgetbridge/.kotlin

# Generated files
gadgetbridge/bin/
gadgetbridge/gen/
gadgetbridge/**/bin/
gadgetbridge/**/gen/

# Gradle files
gadgetbridge/.gradle/
gadgetbridge/build/
gadgetbridge/**/.gradle/
gadgetbridge/**/build/

# Local configuration file (sdk path, etc)
gadgetbridge/local.properties

# Proguard folder generated by Eclipse
gadgetbridge/proguard/
gadgetbridge/**/proguard/

# Log Files
gadgetbridge/**/*.log

# IDE
gadgetbridge/.idea/*
!gadgetbridge/.idea/icon.svg
!gadgetbridge/.idea/dictionaries
gadgetbridge/.idea/dictionaries/*
!gadgetbridge/.idea/dictionaries/t.xml
gadgetbridge/**/*.iml

# Gadgetbridge-specific
gadgetbridge/MPChartLib
gadgetbridge/fw.dirs
gadgetbridge/**/.project
gadgetbridge/**/.settings
gadgetbridge/**/.classpath
gadgetbridge/app/release/output-metadata.json
gadgetbridge/app/.cxx/
gadgetbridge/.attach_pid*

# Nested .gitignore content (GBDaoGenerator, entities, util, res)
gadgetbridge/GBDaoGenerator/bin
gadgetbridge/GBDaoGenerator/build
gadgetbridge/app/src/main/java/nodomain/freeyourgadget/gadgetbridge/util/small/
gadgetbridge/app/src/main/java/nodomain/freeyourgadget/gadgetbridge/util/SmallHelper.java
gadgetbridge/app/src/main/res/values-en

# ---- research/repositories/IDOBlueProtocol (https://github.com/idoosmart/IDOBlueProtocol; no .gitignore upstream) ----
# Swift Package Manager / Xcode
research/repositories/IDOBlueProtocol/.swiftpm/xcode/xcuserdata/
research/repositories/IDOBlueProtocol/.swiftpm/xcode/package.xcworkspace/xcuserdata/
research/repositories/IDOBlueProtocol/.swiftpm/.build/
research/repositories/IDOBlueProtocol/.build/
research/repositories/IDOBlueProtocol/**/.build/
research/repositories/IDOBlueProtocol/DerivedData/
research/repositories/IDOBlueProtocol/**/DerivedData/
research/repositories/IDOBlueProtocol/**/xcuserdata/
research/repositories/IDOBlueProtocol/*.xcworkspace/xcuserdata/
research/repositories/IDOBlueProtocol/*.xcodeproj/xcuserdata/
research/repositories/IDOBlueProtocol/*.xcodeproj/project.xcworkspace/xcuserdata/
# macOS
research/repositories/IDOBlueProtocol/.DS_Store
research/repositories/IDOBlueProtocol/**/.DS_Store
# Xcode user state
research/repositories/IDOBlueProtocol/**/*.xcuserstate
research/repositories/IDOBlueProtocol/**/xcschememanagement.plist

# ---- research/repositories/IDOGitBook (https://github.com/idoosmart/IDOGitBook; no .gitignore upstream) ----
# Mirror style: scoped under IDOGitBook/; typical GitBook / static site ignores
research/repositories/IDOGitBook/.DS_Store
research/repositories/IDOGitBook/**/.DS_Store
research/repositories/IDOGitBook/node_modules/
research/repositories/IDOGitBook/**/node_modules/
research/repositories/IDOGitBook/_book/
research/repositories/IDOGitBook/**/_book/
research/repositories/IDOGitBook/.gitbook/
research/repositories/IDOGitBook/**/.gitbook/
research/repositories/IDOGitBook/*.log
research/repositories/IDOGitBook/**/*.log
research/repositories/IDOGitBook/.cache/
research/repositories/IDOGitBook/**/.cache/
research/repositories/IDOGitBook/book/
research/repositories/IDOGitBook/**/book/

# ---- Flutter / Dart (for research/repositories/Flutter_GitBook and future Flutter tooling) ----
# Build outputs
**/build/
**/.dart_tool/
.dart_tool/

# Flutter/Dart package dependencies (may be regenerated)
.packages
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# IDE / tooling
.idea/
.vscode/
*.iml

# Generated by Flutter/Dart tools
pubspec.lock
analysis_options.yaml

# ---- research/repositories/IDOAndroidBleSDK-_UPDATE (Android Gradle/IDE ignores) ----
research/repositories/IDOAndroidBleSDK-_UPDATE/*.iml
research/repositories/IDOAndroidBleSDK-_UPDATE/.gradle
research/repositories/IDOAndroidBleSDK-_UPDATE/local.properties
research/repositories/IDOAndroidBleSDK-_UPDATE/.idea/
research/repositories/IDOAndroidBleSDK-_UPDATE/build
